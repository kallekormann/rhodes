NEXT_PUBLIC_SUPABASE_URL=http://localhost:3001/app/supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
REDIS_URL=redis://localhost:6379

# Team invite emails (Mailpit UI: http://localhost:8025, SMTP on host port 1026)
SMTP_HOST=127.0.0.1
SMTP_PORT=1026
SMTP_FROM=dev@rhodes.local
SMTP_SENDER_NAME=Rhodes

# Billing tier override for local dev: free | basic | pro | team
NEXT_PUBLIC_MOCK_TIER=free

